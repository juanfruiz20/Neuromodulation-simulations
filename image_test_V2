# MAIN
# =========================================================
def main():
    seed_all(SEED)

    print("Usando dispositivo:", DEVICE)

    # split
    files = list_npz_files(DATA_DIR)
    train_files, val_files, test_files = split_files(
        files,
        seed=SEED,
        train_ratio=TRAIN_RATIO,
        val_ratio=VAL_RATIO
    )

    print(
        f"Total sims: {len(files)} | train={len(train_files)} | val={len(val_files)} | test={len(test_files)}")

    selected_cases = get_case_selection(test_files)
    if len(selected_cases) == 0:
        raise ValueError("No se seleccionó ningún caso para visualizar.")

    print("\nCasos seleccionados:")
    for f in selected_cases:
        print(" -", os.path.basename(f))

    # modelos
    models_info = load_models(CKPT_DIR, CKPT_NAMES, DEVICE)
    model_names = [m["name"] for m in models_info]

    print("\nModelos cargados:")
    for m in models_info:
        print(" -", m["name"])

    # por cada caso: GT + 4 preds
    for case_file in selected_cases:
        case_name = os.path.splitext(os.path.basename(case_file))[0]
        print(f"\nProcesando {case_name}...")

        preds = []
        gt_ref = None

        for model_info in models_info:
            pred_np, gt_np = predict_single_case(model_info, case_file, DEVICE)
            preds.append(pred_np)

            if gt_ref is None:
                gt_ref = gt_np
            else:
                if gt_ref.shape != gt_np.shape:
                    raise ValueError(
                        f"GT con shape distinta en {case_name} para modelo {model_info['name']}"
                    )

        out_cmp = os.path.join(OUT_DIR, f"{case_name}_GT_vs_4models.png")
        save_comparison_figure(
            case_name=case_name,
            gt_np=gt_ref,
            preds=preds,
            model_names=model_names,
            out_path=out_cmp,
            cmap=CMAP,
            overlay_contours=OVERLAY_CONTOURS,
            crosshair=DRAW_CROSSHAIR,
        )

        if SAVE_ABS_ERR:
            out_err = os.path.join(OUT_DIR, f"{case_name}_AbsErr_4models.png")
            save_abs_error_figure(
                case_name=case_name,
                gt_np=gt_ref,
                preds=preds,
                model_names=model_names,
                out_path=out_err,
                cmap=CMAP,
                crosshair=DRAW_CROSSHAIR,
            )

    print("\nListo.")
    print("Figuras guardadas en:")
    print(OUT_DIR)


if __name__ == "__main__":
    main()
